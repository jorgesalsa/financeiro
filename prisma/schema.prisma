generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CONTROLLER
  ANALYST
  VIEWER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BankAccountType {
  CHECKING
  SAVINGS
  INVESTMENT
}

enum PaymentMethodType {
  CASH
  BANK_TRANSFER
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CHECK
  OTHER
}

enum ClassificationField {
  CNPJ
  DESCRIPTION
  VALUE_RANGE
}

enum ImportType {
  TAX_INVOICE
  BANK_STATEMENT
  CARD_TRANSACTION
  PURCHASE_INVOICE
  PLUGGY_SYNC
  QIVE_SYNC
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CardTransactionStatus {
  PENDING
  SETTLED
  CANCELLED
}

enum StagingSource {
  MANUAL
  IMPORT_TAX_INVOICE
  IMPORT_BANK_STATEMENT
  IMPORT_CARD
  IMPORT_PURCHASE_INVOICE
  IMPORT_PLUGGY
  IMPORT_QIVE
}

enum StagingStatus {
  PENDING
  AUTO_CLASSIFIED
  VALIDATED
  INCORPORATED
  REJECTED
}

enum EntryStatus {
  OPEN
  PARTIAL
  SETTLED
  CANCELLED
}

enum EntryCategory {
  PAYABLE
  RECEIVABLE
  TRANSFER
  ADJUSTMENT
}

enum MatchType {
  AUTO_EXACT
  AUTO_DATE_TOLERANCE
  AUTO_VALUE_TOLERANCE
  MANUAL
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum QiveConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

enum PluggyConnectionStatus {
  LOGIN_IN_PROGRESS
  WAITING_USER_INPUT
  OUTDATED
  UPDATED
  ERROR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  cnpj      String
  slug      String   @unique
  active    Boolean  @default(true)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  invites            TenantInvite[]
  chartOfAccounts    ChartOfAccount[]
  suppliers          Supplier[]
  customers          Customer[]
  costCenters        CostCenter[]
  bankAccounts       BankAccount[]
  paymentMethods     PaymentMethod[]
  products           Product[]
  warehouses         Warehouse[]
  classificationRules ClassificationRule[]
  periodLocks        PeriodLock[]
  importBatches      ImportBatch[]
  taxInvoiceLines    TaxInvoiceLine[]
  bankStatementLines BankStatementLine[]
  cardTransactions   CardTransaction[]
  purchaseInvoices   PurchaseInvoice[]
  stagingEntries     StagingEntry[]
  officialEntries    OfficialEntry[]
  settlements        Settlement[]
  reconciliations    Reconciliation[]
  recurringRules     RecurringRule[]
  budgetLines        BudgetLine[]
  closingChecklists  ClosingChecklist[]
  stockMovements     StockMovement[]
  auditLogs          AuditLog[]
  pluggyConnections  PluggyConnection[]
  qiveConnections    QiveConnection[]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           Role      @default(VIEWER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships    Membership[]
  accounts       Account[]
  sessions       Session[]

  lockedPeriods             PeriodLock[]          @relation("PeriodLockedBy")
  importedBatches           ImportBatch[]         @relation("ImportedBy")
  validatedStagingEntries   StagingEntry[]        @relation("ValidatedBy")
  createdStagingEntries     StagingEntry[]        @relation("CreatedBy")
  incorporatedOfficialEntries OfficialEntry[]     @relation("IncorporatedBy")
  settledSettlements        Settlement[]          @relation("SettledBy")
  reconciledReconciliations Reconciliation[]      @relation("ReconciledBy")
  createdRecurringRules     RecurringRule[]        @relation("RecurringRuleCreatedBy")
  completedChecklists       ClosingChecklist[]    @relation("ChecklistCompletedBy")
  createdStockMovements     StockMovement[]       @relation("StockMovementCreatedBy")
  createdPluggyConnections  PluggyConnection[]    @relation("PluggyConnectionCreatedBy")
  createdQiveConnections    QiveConnection[]      @relation("QiveConnectionCreatedBy")
  createdInvites            TenantInvite[]        @relation("InviteCreatedBy")
  notifications             Notification[]        @relation("NotificationUser")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(VIEWER)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ChartOfAccount {
  id         String      @id @default(cuid())
  tenantId   String
  code       String
  name       String
  type       AccountType
  level      Int
  parentId   String?
  isAnalytic Boolean     @default(true)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ChartOfAccount? @relation("ChartOfAccountParent", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("ChartOfAccountParent")

  classificationRules ClassificationRule[]
  stagingEntries      StagingEntry[]
  officialEntries     OfficialEntry[]
  recurringRules      RecurringRule[]
  budgetLines         BudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

model Supplier {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  tradeName         String?
  cnpjCpf           String
  stateRegistration String?
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  notes             String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  classificationRules ClassificationRule[]
  purchaseInvoices    PurchaseInvoice[]
  stagingEntries      StagingEntry[]
  officialEntries     OfficialEntry[]
  recurringRules      RecurringRule[]

  @@unique([tenantId, cnpjCpf])
  @@index([tenantId])
}

model Customer {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  tradeName         String?
  cnpjCpf           String
  stateRegistration String?
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  notes             String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  classificationRules ClassificationRule[]
  stagingEntries      StagingEntry[]
  officialEntries     OfficialEntry[]
  recurringRules      RecurringRule[]

  @@unique([tenantId, cnpjCpf])
  @@index([tenantId])
}

model CostCenter {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  parentId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   CostCenter? @relation("CostCenterParent", fields: [parentId], references: [id])
  children CostCenter[] @relation("CostCenterParent")

  classificationRules ClassificationRule[]
  stagingEntries      StagingEntry[]
  officialEntries     OfficialEntry[]
  recurringRules      RecurringRule[]
  budgetLines         BudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

model BankAccount {
  id             String          @id @default(cuid())
  tenantId       String
  bankName       String
  bankCode       String
  agency         String
  accountNumber  String
  accountType    BankAccountType
  initialBalance Decimal
  currentBalance Decimal
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bankStatementLines BankStatementLine[]
  stagingEntries     StagingEntry[]
  officialEntries    OfficialEntry[]
  settlements        Settlement[]
  recurringRules     RecurringRule[]
  pluggyConnections  PluggyConnection[]

  @@unique([tenantId, bankCode, agency, accountNumber])
  @@index([tenantId])
}

model PaymentMethod {
  id            String            @id @default(cuid())
  tenantId      String
  name          String
  type          PaymentMethodType
  daysToSettle  Int               @default(0)
  feePercentage Decimal           @default(0)
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stagingEntries  StagingEntry[]
  officialEntries OfficialEntry[]
  settlements     Settlement[]
  recurringRules  RecurringRule[]

  @@index([tenantId])
}

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  name         String
  description  String?
  unit         String
  costPrice    Decimal
  salePrice    Decimal
  minStock     Decimal  @default(0)
  reorderPoint Decimal  @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  purchaseInvoiceItems PurchaseInvoiceItem[]
  stockMovements       StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stockMovements StockMovement[]

  @@index([tenantId])
}

model ClassificationRule {
  id               String              @id @default(cuid())
  tenantId         String
  priority         Int
  field            ClassificationField
  pattern          String
  chartOfAccountId String?
  costCenterId     String?
  supplierId       String?
  customerId       String?
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount? @relation(fields: [chartOfAccountId], references: [id])
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, priority])
}

model PeriodLock {
  id         String   @id @default(cuid())
  tenantId   String
  year       Int
  month      Int
  lockedAt   DateTime
  lockedById String
  createdAt  DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lockedBy User   @relation("PeriodLockedBy", fields: [lockedById], references: [id])

  @@unique([tenantId, year, month])
  @@index([tenantId])
}

model ImportBatch {
  id               String       @id @default(cuid())
  tenantId         String
  type             ImportType
  fileName         String
  status           ImportStatus @default(PENDING)
  totalRecords     Int          @default(0)
  processedRecords Int          @default(0)
  errorRecords     Int          @default(0)
  importedById     String
  createdAt        DateTime     @default(now())
  completedAt      DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importedBy User   @relation("ImportedBy", fields: [importedById], references: [id])

  taxInvoiceLines    TaxInvoiceLine[]
  bankStatementLines BankStatementLine[]
  cardTransactions   CardTransaction[]
  purchaseInvoices   PurchaseInvoice[]
  stagingEntries     StagingEntry[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model TaxInvoiceLine {
  id                 String   @id @default(cuid())
  tenantId           String
  importBatchId      String
  invoiceNumber      String
  series             String?
  issueDate          DateTime
  cnpjIssuer         String
  issuerName         String
  cnpjRecipient      String
  cfop               String
  productCode        String?
  productDescription String?
  ncm                String?
  quantity           Decimal
  unitPrice          Decimal
  totalValue         Decimal
  icmsValue          Decimal
  ipiValue           Decimal
  pisValue           Decimal
  cofinsValue        Decimal
  accessKey          String?
  externalId         String?
  createdAt          DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([importBatchId])
  @@index([tenantId, cnpjIssuer])
}

model BankStatementLine {
  id              String          @id @default(cuid())
  tenantId        String
  importBatchId   String
  bankAccountId   String
  transactionDate DateTime
  description     String
  document        String?
  amount          Decimal
  balance         Decimal
  type            TransactionType
  externalId      String?
  createdAt       DateTime        @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  reconciliation Reconciliation?

  @@unique([tenantId, bankAccountId, externalId])
  @@index([tenantId])
  @@index([importBatchId])
  @@index([bankAccountId])
  @@index([tenantId, transactionDate])
}

model CardTransaction {
  id                String                @id @default(cuid())
  tenantId          String
  importBatchId     String
  cardBrand         String
  lastFourDigits    String
  transactionDate   DateTime
  settlementDate    DateTime?
  description       String
  grossAmount       Decimal
  feeAmount         Decimal
  netAmount         Decimal
  installmentNumber Int                   @default(1)
  totalInstallments Int                   @default(1)
  authorizationCode String?
  status            CardTransactionStatus @default(PENDING)
  createdAt         DateTime              @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([importBatchId])
  @@index([tenantId, transactionDate])
  @@index([tenantId, status])
}

model PurchaseInvoice {
  id            String    @id @default(cuid())
  tenantId      String
  importBatchId String?
  invoiceNumber String
  series        String?
  issueDate     DateTime
  supplierId    String
  totalValue    Decimal
  discountValue Decimal   @default(0)
  freightValue  Decimal   @default(0)
  otherCosts    Decimal   @default(0)
  netValue      Decimal
  accessKey     String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])
  supplier    Supplier     @relation(fields: [supplierId], references: [id])

  items PurchaseInvoiceItem[]

  @@index([tenantId])
  @@index([importBatchId])
  @@index([supplierId])
  @@index([tenantId, issueDate])
}

model PurchaseInvoiceItem {
  id                String  @id @default(cuid())
  purchaseInvoiceId String
  productId         String
  quantity          Decimal
  unitPrice         Decimal
  totalPrice        Decimal
  icmsValue         Decimal @default(0)
  ipiValue          Decimal @default(0)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])

  @@index([purchaseInvoiceId])
  @@index([productId])
}

model StagingEntry {
  id                 String         @id @default(cuid())
  tenantId           String
  importBatchId      String?
  source             StagingSource
  status             StagingStatus  @default(PENDING)
  date               DateTime
  description        String
  amount             Decimal
  type               TransactionType
  counterpartCnpjCpf String?
  counterpartName    String?
  chartOfAccountId   String?
  costCenterId       String?
  supplierId         String?
  customerId         String?
  bankAccountId      String?
  paymentMethodId    String?
  notes              String?
  validatedById      String?
  validatedAt        DateTime?
  rejectionReason    String?
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch?    @relation(fields: [importBatchId], references: [id])
  chartOfAccount ChartOfAccount? @relation(fields: [chartOfAccountId], references: [id])
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  bankAccount    BankAccount?    @relation(fields: [bankAccountId], references: [id])
  paymentMethod  PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  validatedBy    User?           @relation("ValidatedBy", fields: [validatedById], references: [id])
  createdBy      User            @relation("CreatedBy", fields: [createdById], references: [id])

  officialEntry OfficialEntry?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([importBatchId])
  @@index([tenantId, date])
}

model OfficialEntry {
  id                 String          @id @default(cuid())
  tenantId           String
  sequentialNumber   Int
  date               DateTime
  competenceDate     DateTime
  description        String
  amount             Decimal
  type               TransactionType
  status             EntryStatus     @default(OPEN)
  category           EntryCategory
  chartOfAccountId   String
  costCenterId       String?
  supplierId         String?
  customerId         String?
  bankAccountId      String
  paymentMethodId    String?
  documentNumber     String?
  dueDate            DateTime?
  originalDueDate    DateTime?
  paidDate           DateTime?
  paidAmount         Decimal?
  interestAmount     Decimal         @default(0)
  fineAmount         Decimal         @default(0)
  discountAmount     Decimal         @default(0)
  installmentGroupId String?
  installmentNumber  Int?
  totalInstallments  Int?
  recurringRuleId    String?
  stagingEntryId     String?         @unique
  notes              String?
  incorporatedById   String
  incorporatedAt     DateTime
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount  @relation(fields: [chartOfAccountId], references: [id])
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])
  paymentMethod  PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  recurringRule  RecurringRule?  @relation(fields: [recurringRuleId], references: [id])
  stagingEntry   StagingEntry?   @relation(fields: [stagingEntryId], references: [id])
  incorporatedBy User            @relation("IncorporatedBy", fields: [incorporatedById], references: [id])

  settlements     Settlement[]
  reconciliations Reconciliation[]

  @@unique([tenantId, sequentialNumber])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, competenceDate])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, dueDate])
  @@index([chartOfAccountId])
  @@index([bankAccountId])
  @@index([supplierId])
  @@index([customerId])
  @@index([recurringRuleId])
  @@index([installmentGroupId])
}

model Settlement {
  id              String   @id @default(cuid())
  tenantId        String
  officialEntryId String
  date            DateTime
  amount          Decimal
  interestAmount  Decimal  @default(0)
  fineAmount      Decimal  @default(0)
  discountAmount  Decimal  @default(0)
  bankAccountId   String
  paymentMethodId String?
  document        String?
  notes           String?
  settledById     String
  createdAt       DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officialEntry OfficialEntry  @relation(fields: [officialEntryId], references: [id])
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  settledBy     User           @relation("SettledBy", fields: [settledById], references: [id])

  reconciliation Reconciliation?

  @@index([tenantId])
  @@index([officialEntryId])
  @@index([tenantId, date])
}

model Reconciliation {
  id                  String    @id @default(cuid())
  tenantId            String
  bankStatementLineId String    @unique
  officialEntryId     String?
  settlementId        String?   @unique
  matchType           MatchType
  reconciledById      String
  reconciledAt        DateTime
  notes               String?
  createdAt           DateTime  @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankStatementLine BankStatementLine  @relation(fields: [bankStatementLineId], references: [id])
  officialEntry     OfficialEntry?     @relation(fields: [officialEntryId], references: [id])
  settlement        Settlement?        @relation(fields: [settlementId], references: [id])
  reconciledBy      User               @relation("ReconciledBy", fields: [reconciledById], references: [id])

  @@index([tenantId])
  @@index([officialEntryId])
}

model RecurringRule {
  id                 String        @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  amount             Decimal
  type               TransactionType
  category           EntryCategory
  chartOfAccountId   String
  costCenterId       String?
  supplierId         String?
  customerId         String?
  bankAccountId      String
  paymentMethodId    String?
  frequency          Frequency
  dayOfMonth         Int?
  startDate          DateTime
  endDate            DateTime?
  nextGenerationDate DateTime
  active             Boolean       @default(true)
  createdById        String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount  @relation(fields: [chartOfAccountId], references: [id])
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])
  paymentMethod  PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  createdBy      User            @relation("RecurringRuleCreatedBy", fields: [createdById], references: [id])

  officialEntries OfficialEntry[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@index([nextGenerationDate])
}

model BudgetLine {
  id               String   @id @default(cuid())
  tenantId         String
  year             Int
  month            Int
  chartOfAccountId String
  costCenterId     String?
  budgetAmount     Decimal
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  costCenter     CostCenter?    @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, year, month, chartOfAccountId, costCenterId])
  @@index([tenantId])
  @@index([tenantId, year, month])
}

model ClosingChecklist {
  id            String          @id @default(cuid())
  tenantId      String
  year          Int
  month         Int
  item          String
  description   String?
  status        ChecklistStatus @default(PENDING)
  severity      Severity
  completedById String?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  completedBy User?  @relation("ChecklistCompletedBy", fields: [completedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, year, month])
}

model StockMovement {
  id               String            @id @default(cuid())
  tenantId         String
  productId        String
  warehouseId      String
  type             StockMovementType
  quantity         Decimal
  unitCost         Decimal
  totalCost        Decimal
  balanceAfter     Decimal
  averageCostAfter Decimal
  referenceType    String?
  referenceId      String?
  notes            String?
  createdById      String
  createdAt        DateTime          @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  createdBy User      @relation("StockMovementCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([tenantId, productId, warehouseId])
  @@index([tenantId, createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  tableName String
  recordId  String
  action    AuditAction
  oldValues Json?
  newValues Json?
  userId    String
  userEmail String
  ipAddress String?
  createdAt DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tableName])
  @@index([tenantId, tableName, recordId])
  @@index([tenantId, createdAt])
  @@index([userId])
}

model PluggyConnection {
  id              String                  @id @default(cuid())
  tenantId        String
  pluggyItemId    String                  @unique
  connectorId     Int
  connectorName   String
  connectorLogo   String?
  status          PluggyConnectionStatus  @default(LOGIN_IN_PROGRESS)
  lastSyncAt      DateTime?
  executionError  String?
  bankAccountId   String?
  pluggyAccountId String?
  createdById     String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  createdBy   User         @relation("PluggyConnectionCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

model QiveConnection {
  id             String                @id @default(cuid())
  tenantId       String
  status         QiveConnectionStatus  @default(ACTIVE)
  lastSyncAt     DateTime?
  lastCursor     String?
  executionError String?
  createdById    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("QiveConnectionCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
}

// ─── Multi-Tenant Management ─────────────────────────────────────────────────

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model TenantInvite {
  id        String       @id @default(cuid())
  tenantId  String
  email     String
  role      Role         @default(VIEWER)
  status    InviteStatus @default(PENDING)
  token     String       @unique @default(cuid())
  expiresAt DateTime
  createdById String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([token])
}

// ─── Notifications ───────────────────────────────────────────────────────────

enum NotificationType {
  STAGING_PENDING
  OVERDUE_PAYABLE
  OVERDUE_RECEIVABLE
  IMPORT_COMPLETED
  INVITE_RECEIVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String?
  type      NotificationType
  title     String
  message   String
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
